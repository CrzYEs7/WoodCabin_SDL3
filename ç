#pragma once 

#include "Application.h"
#include <cstdint>

namespace Game
{
    const uint16_t MAX_THINGS = 5;

    struct Vec2
    {
    	float x,y;
    };

    enum Kind
    {
	Nil,
	Player,
	Monster,
	Prop
    };

    typedef struct 
    {
	int Next;
    } FreeSlotRef;

    struct ThingRef
    {
	int Index;
	int Generation;

	const static ThingRef Nil()
	{
	    return {0, 0};
	}
    };

    struct Thing
    {
	Kind kind;
	Vec2 position;
	float speed;

	operator bool()
	{
            return kind != Kind::Nil;
	}
    };

    class Things
    {
    public:	
	ThingRef Add(Kind kind);
	void Remove(ThingRef ref);

  	bool& isUsed(ThingRef ref)
	{
            return m_Used[ref.Index];
	}

	Thing& Get(ThingRef ref)
	{
	    return m_Things[Deref(ref)];
	}

	friend class Core::Application;
    private:
	int Deref(ThingRef ref);

	Thing m_Things[MAX_THINGS];
	bool m_Used[MAX_THINGS];
	int m_Generation[MAX_THINGS];
	FreeSlotRef m_FreeList[MAX_THINGS];
	int m_FirstFree = 1;
    };
}
